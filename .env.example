# ─── rpiCoffee environment configuration ──────────────────────
# Copy to .env and adjust values.  setup.sh does this automatically.

# App secret – used for session signing (auto-generated by setup.sh)
SECRET_KEY=change-me-to-a-random-string

# Admin dashboard password (only used on first run to seed the hash)
ADMIN_PASSWORD=1234

# ─── Sensor ───────────────────────────────────────────────────
# mock | picoquake | serial
SENSOR_MODE=picoquake
# Last 4 hex chars of PicoQuake serial number
SENSOR_DEVICE_ID=cf79
# Automatically start brew pipeline when vibration exceeds threshold
SENSOR_AUTO_TRIGGER=true

# ─── Services (true / false) ─────────────────────────────────
CLASSIFIER_ENABLED=true
LLM_ENABLED=true
LLM_BACKEND=llama-cpp
# LLM_BACKEND=ollama        # use for Hailo AI HAT+ / hailo-ollama (external, not Docker-managed)
# LLM_MODEL=qwen2:1.5b      # Ollama model name (only when LLM_BACKEND=ollama)
TTS_ENABLED=true
REMOTE_SAVE_ENABLED=true

# ─── Service ports ────────────────────────────────────────────
# Single source of truth – used by docker-compose.yml,
# start.sh, status.sh, and the launcher scripts.
APP_PORT=8080
CLASSIFIER_PORT=8001
LLM_PORT=8002
OLLAMA_PORT=8000
TTS_PORT=5050
REMOTE_SAVE_PORT=7000

# ─── Service endpoints (localhost for native-app mode) ────────
CLASSIFIER_ENDPOINT=http://localhost:${CLASSIFIER_PORT}
LLM_ENDPOINT=http://localhost:${LLM_PORT}LLM_OLLAMA_ENDPOINT=http://localhost:${OLLAMA_PORT}TTS_ENDPOINT=http://localhost:${TTS_PORT}
REMOTE_SAVE_ENDPOINT=http://localhost:${REMOTE_SAVE_PORT}
