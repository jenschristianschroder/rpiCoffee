# ─── rpiCoffee environment configuration ──────────────────────
# Copy to .env and adjust values.  setup.sh does this automatically.

# App secret – used for session signing (auto-generated by setup.sh)
SECRET_KEY=change-me-to-a-random-string

# Admin dashboard password (only used on first run to seed the hash)
ADMIN_PASSWORD=1234

# ─── Sensor ───────────────────────────────────────────────────
# mock | picoquake | serial
SENSOR_MODE=picoquake
# Last 4 hex chars of PicoQuake serial number
SENSOR_DEVICE_ID=cf79

# ─── Services (true / false) ─────────────────────────────────
CLASSIFIER_ENABLED=true
LLM_ENABLED=true
TTS_ENABLED=true
REMOTE_SAVE_ENABLED=true

# ─── Service endpoints (localhost for native-app mode) ────────
CLASSIFIER_ENDPOINT=http://localhost:8001
LLM_ENDPOINT=http://localhost:8000
TTS_ENDPOINT=http://localhost:5050
REMOTE_SAVE_ENDPOINT=http://localhost:7000
