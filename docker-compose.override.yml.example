# docker-compose.override.yml — Raspberry Pi production overrides
#
# Copy this file to docker-compose.override.yml and adjust for your Pi:
#
#   cp docker-compose.override.yml.example docker-compose.override.yml
#
# Docker Compose automatically merges it with docker-compose.yml.

services:
  app:
    environment:
      - SENSOR_MODE=picoquake
      - SENSOR_DEVICE_ID=cf79
    # Pass the PicoQuake USB device into the container
    devices:
      - "/dev/ttyACM0:/dev/ttyACM0"
